{
  "env": {
    "BASH_DEFAULT_TIMEOUT_MS": "600000",
    "BASH_MAX_TIMEOUT_MS": "1200000",
    "BASH_MAX_OUTPUT_LENGTH": "30000",
    "MAX_MCP_OUTPUT_TOKENS": "25000",
    "ENABLE_TOOL_SEARCH": "true",
    "MCP_TIMEOUT": "60000",
    "MCP_TOOL_TIMEOUT": "300000",
    "API_TIMEOUT_MS": "600000",
    "CLAUDE_CODE_MAX_OUTPUT_TOKENS": "64000"
  },
  "attribution": {
    "commit": "",
    "pr": "",
    "sessionUrl": false
  },
  "includeCoAuthoredBy": false,
  "outputStyle": "operating-policy",
  "effortLevel": "xhigh",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/.claude/hooks/policy-context.sh\"",
            "shell": "bash",
            "timeout": 5
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/.claude/hooks/policy-context.sh\"",
            "shell": "bash",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolBatch": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/.claude/hooks/policy-context.sh\"",
            "shell": "bash",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/.claude/hooks/policy-context.sh\"",
            "shell": "bash",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "^Agent$",
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/.claude/hooks/policy-context.sh\"",
            "shell": "bash",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
